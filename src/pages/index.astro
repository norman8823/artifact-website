---
import Base from "../layouts/Base.astro";
import HeroVideo from "../components/HeroVideo.astro";
import StorySection from "../components/StorySection.astro";
import StoryVideo from "../components/StoryVideo.astro";
import DeviceFrame from "../components/DeviceFrame.astro";
import Faq from "../components/Faq.astro";
import { CTA_URL, CTA_LABEL } from "../consts";
---

<Base>
  {/* ---------------------------------------------------------------- HERO */}
  <section class="hero">
    <div class="mx-auto max-w-3xl px-6 pt-14 text-center sm:pt-20">
      <p
        class="mb-6 text-xs font-medium uppercase tracking-[0.22em] text-[var(--color-muted)]"
      >
        An iOS museum companion
      </p>
      <h1
        class="mx-auto max-w-2xl font-serif text-[2.75rem] leading-[1.05] tracking-tight text-[var(--color-ink)] sm:text-6xl"
      >
        The Museum Experience, reimagined.
      </h1>
      <p
        class="mx-auto mt-6 max-w-lg text-lg leading-relaxed text-[var(--color-muted)]"
      >
        Explore art in the MET through guided quests and immersive augmented
        reality.
      </p>
      <div class="mt-9">
        <a
          href={CTA_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center rounded-full bg-[var(--color-accent)] px-7 py-3.5 text-base font-medium text-white shadow-sm transition-colors hover:bg-[var(--color-accent-hover)]"
        >
          {CTA_LABEL}
        </a>
      </div>
    </div>

    {/* The demo phone — large, front and centre */}
    <div class="mx-auto mt-14 flex max-w-6xl justify-center px-6 sm:mt-16">
      <HeroVideo maxWidth={400} />
    </div>

    {/* Subtle "scroll down to explore" cue */}
    <a href="#explore" class="scroll-cue" aria-label="Scroll down to explore">
      <span>Explore</span>
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <path
          d="M6 9l6 6 6-6"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"></path>
      </svg>
    </a>
  </section>

  {/* ------------------------------------------------------------- STORIES */}

  {/* Explore — quests */}
  <StorySection
    id="explore"
    eyebrow="Explore"
    title="Explore the museum like a scavenger hunt."
    reversed={false}
  >
    <Fragment slot="body">
      <p>
        Follow interactive quests that turn your visit into a scavenger hunt —
        discover featured artworks, scan them as you go, and track your
        progress along the way.
      </p>
    </Fragment>
    <StoryVideo
      slot="media"
      src="/assets/browse-art-quests.mp4"
      label="Browsing art quests in the ARtifact app"
      maxWidth={300}
    />
  </StorySection>

  {/* Learn — browse & detail */}
  <StorySection
    eyebrow="Learn"
    title="Go deeper than the wall label."
    reversed={true}
  >
    <Fragment slot="body">
      <p>
        Browse artworks, revisit your discoveries, and dive into the artists,
        history, and context behind each piece. Every artwork detail page is
        reachable through a quest — or simply by browsing.
      </p>
    </Fragment>
    <StoryVideo
      slot="media"
      src="/assets/infinite-scroll.mp4"
      label="Browsing artworks on the Explore screen"
      maxWidth={300}
    />
  </StorySection>

  {/* See in 3D — AR */}
  <StorySection
    eyebrow="See in 3D"
    title="View artworks in augmented reality."
    reversed={false}
  >
    <Fragment slot="body">
      <p>
        Experience select cultural objects in augmented reality — from every
        angle, wherever you are.
      </p>
    </Fragment>
    <DeviceFrame
      slot="media"
      maxWidth={300}
      label="The Banda Mask placed in augmented reality"
    >
      <img
        src="/assets/banda-ar.jpg"
        alt="The Banda Mask shown in augmented reality"
        width="390"
        height="830"
        loading="lazy"
      />
    </DeviceFrame>
  </StorySection>

  {/* ----------------------------------------------------------------- FAQ */}
  <section id="faq" class="border-t border-[var(--color-hairline)]">
    <div class="mx-auto max-w-3xl px-6 py-20 sm:py-28">
      <div class="reveal mb-10 text-center">
        <h2
          class="font-serif text-3xl tracking-tight text-[var(--color-ink)] sm:text-4xl"
        >
          Questions
        </h2>
      </div>
      <div class="reveal">
        <Faq />
      </div>
    </div>
  </section>

  {/* ------------------------------------------------------------ CTA CODA */}
  <section class="border-t border-[var(--color-hairline)]">
    <div class="mx-auto max-w-3xl px-6 py-20 text-center sm:py-28">
      <h2
        class="reveal font-serif text-3xl tracking-tight text-[var(--color-ink)] sm:text-[2.5rem]"
      >
        Start exploring.
      </h2>
      <p class="reveal mx-auto mt-4 max-w-md text-lg text-[var(--color-muted)]">
        Join the beta and be among the first to experience the museum through
        ARtifact.
      </p>
      <div class="reveal mt-8">
        <a
          href={CTA_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center rounded-full bg-[var(--color-accent)] px-7 py-3.5 text-base font-medium text-white shadow-sm transition-colors hover:bg-[var(--color-accent-hover)]"
        >
          {CTA_LABEL}
        </a>
      </div>
    </div>
  </section>
</Base>

<style>
  .hero {
    position: relative;
  }

  .scroll-cue {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.4rem;
    width: max-content;
    margin: 0 auto;
    padding-bottom: 2.5rem;
    font-size: 0.7rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-muted);
    transition: color 0.25s ease;
  }
  .scroll-cue:hover {
    color: var(--color-ink);
  }
  .scroll-cue svg {
    animation: nudge 2.4s ease-in-out infinite;
  }

  @keyframes nudge {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(4px);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .scroll-cue svg {
      animation: none;
    }
  }
</style>
