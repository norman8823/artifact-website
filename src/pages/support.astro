---
import Base from "../layouts/Base.astro";
import { CONTACT_EMAIL, CTA_URL, CTA_LABEL } from "../consts";
---

<Base
  title="Contact — ARtifact"
  description="Get in touch with the ARtifact team, or request account deletion."
>
  <section class="mx-auto max-w-3xl px-6 py-24 sm:py-32">
    <p
      class="mb-5 text-xs font-medium uppercase tracking-[0.22em] text-[var(--color-accent)]"
    >
      Contact
    </p>
    <h1
      class="font-serif text-4xl leading-tight tracking-tight text-[var(--color-ink)] sm:text-5xl"
    >
      We'd love to hear from you.
    </h1>
    <p class="mt-6 max-w-xl text-lg leading-relaxed text-[var(--color-muted)]">
      Questions about ARtifact, feedback from the beta, or a request to delete
      your account and data — reach us anytime by email.
    </p>

    <div class="mt-10">
      <a
        href={`mailto:${CONTACT_EMAIL}`}
        class="inline-flex items-center gap-3 font-serif text-2xl text-[var(--color-ink)] transition-colors hover:text-[var(--color-accent)] sm:text-3xl"
      >
        {CONTACT_EMAIL}
      </a>
    </div>

    <div
      class="mt-14 border-t border-[var(--color-hairline)] pt-10 text-[var(--color-muted)]"
    >
      <p>
        Want to try the app? {" "}
        <a
          href={CTA_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="font-medium text-[var(--color-accent)] hover:text-[var(--color-accent-hover)]"
          >{CTA_LABEL}</a
        >.
      </p>
    </div>
  </section>
</Base>
