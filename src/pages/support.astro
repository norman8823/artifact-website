---
import Base from "../layouts/Base.astro";
import BackLink from "../components/BackLink.astro";
import { CONTACT_EMAIL, CONTACT_FORM_ENDPOINT } from "../consts";
---

<Base
  title="Contact — ARtifact"
  description="Get in touch with the ARtifact team."
>
  <section class="mx-auto max-w-2xl px-6 py-24 sm:py-32">
    <BackLink class="mb-10" />
    <p
      class="mb-5 text-xs font-medium uppercase tracking-[0.22em] text-[var(--color-accent)]"
    >
      Contact
    </p>
    <h1
      class="font-serif text-4xl leading-tight tracking-tight text-[var(--color-ink)] sm:text-5xl"
    >
      We'd love to hear from you.
    </h1>
    <p class="mt-6 max-w-xl text-lg leading-relaxed text-[var(--color-muted)]">
      Questions about ARtifact, or feedback from the beta? Send us a note and
      we'll get back to you.
    </p>

    <form
      class="contact-form mt-12"
      data-contact-form
      data-endpoint={CONTACT_FORM_ENDPOINT}
      data-email={CONTACT_EMAIL}
      action={CONTACT_FORM_ENDPOINT}
      method="POST"
      novalidate
    >
      <div class="field">
        <label for="cf-name">Name</label>
        <input id="cf-name" name="name" type="text" autocomplete="name" required />
      </div>

      <div class="field">
        <label for="cf-email">Email</label>
        <input
          id="cf-email"
          name="email"
          type="email"
          autocomplete="email"
          required
        />
      </div>

      <div class="field">
        <label for="cf-message">Message</label>
        <textarea id="cf-message" name="message" rows="6" required></textarea>
      </div>

      {/* Honeypot — hidden from people, catches bots. */}
      <div class="hp" aria-hidden="true">
        <label for="cf-company">Company</label>
        <input id="cf-company" name="_gotcha" type="text" tabindex="-1" autocomplete="off" />
      </div>

      <button type="submit" class="submit">Send message</button>

      <p class="form-status" data-status role="status" aria-live="polite"></p>
    </form>

    <p class="mt-10 text-sm text-[var(--color-muted)]">
      Prefer email? Reach us directly at{" "}
      <a
        href={`mailto:${CONTACT_EMAIL}`}
        class="text-[var(--color-accent)] underline-offset-2 hover:underline"
        >{CONTACT_EMAIL}</a
      >.
    </p>
  </section>
</Base>

<style>
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  .field {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .field label {
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.02em;
    color: var(--color-ink);
  }
  .field input,
  .field textarea {
    width: 100%;
    padding: 0.75rem 0.9rem;
    font: inherit;
    color: var(--color-ink);
    background: #fff;
    border: 1px solid var(--color-hairline);
    border-radius: 10px;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }
  .field input:focus,
  .field textarea:focus {
    outline: none;
    border-color: var(--color-accent);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--color-accent) 14%, transparent);
  }
  .field textarea {
    resize: vertical;
    min-height: 8rem;
  }

  /* Honeypot: visually and semantically removed from the flow. */
  .hp {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
    overflow: hidden;
  }

  .submit {
    align-self: flex-start;
    margin-top: 0.25rem;
    border-radius: 9999px;
    background: var(--color-accent);
    color: #fff;
    font-weight: 500;
    padding: 0.85rem 1.75rem;
    cursor: pointer;
    transition: background-color 0.2s ease;
  }
  .submit:hover {
    background: var(--color-accent-hover);
  }
  .submit:disabled {
    opacity: 0.6;
    cursor: default;
  }

  .form-status {
    margin: 0;
    font-size: 0.9rem;
    min-height: 1.25rem;
  }
  .form-status[data-state="success"] {
    color: var(--color-ink);
  }
  .form-status[data-state="error"] {
    color: var(--color-accent);
  }
</style>

<script>
  document
    .querySelectorAll<HTMLFormElement>("form[data-contact-form]")
    .forEach((form) => {
      const endpoint = form.dataset.endpoint ?? "";
      const email = form.dataset.email ?? "";
      const status = form.querySelector<HTMLElement>("[data-status]");
      const submit = form.querySelector<HTMLButtonElement>('button[type="submit"]');
      // Treat the un-configured placeholder as "no back-end yet".
      const configured = endpoint !== "" && !endpoint.includes("your-form-id");

      const setStatus = (msg: string, state: "success" | "error" | "") => {
        if (!status) return;
        status.textContent = msg;
        if (state) status.dataset.state = state;
        else status.removeAttribute("data-state");
      };

      const mailtoFallback = () => {
        const name = (form.elements.namedItem("name") as HTMLInputElement)?.value ?? "";
        const from = (form.elements.namedItem("email") as HTMLInputElement)?.value ?? "";
        const message =
          (form.elements.namedItem("message") as HTMLTextAreaElement)?.value ?? "";
        const body = encodeURIComponent(
          `${message}\n\n— ${name} (${from})`,
        );
        window.location.href = `mailto:${email}?subject=${encodeURIComponent(
          "ARtifact — message from " + (name || "the website"),
        )}&body=${body}`;
      };

      form.addEventListener("submit", async (e) => {
        e.preventDefault();

        // Honeypot tripped → silently succeed without sending.
        if ((form.elements.namedItem("_gotcha") as HTMLInputElement)?.value) {
          setStatus("Thanks — your message has been sent.", "success");
          form.reset();
          return;
        }

        if (!form.checkValidity()) {
          form.reportValidity();
          return;
        }

        if (!configured) {
          // No form back-end wired up yet: hand off to the email client.
          mailtoFallback();
          return;
        }

        submit && (submit.disabled = true);
        setStatus("Sending…", "");

        try {
          const res = await fetch(endpoint, {
            method: "POST",
            headers: { Accept: "application/json" },
            body: new FormData(form),
          });
          if (res.ok) {
            form.reset();
            setStatus("Thanks — your message has been sent.", "success");
          } else {
            setStatus(
              `Something went wrong. Please email us at ${email}.`,
              "error",
            );
          }
        } catch {
          setStatus(`Something went wrong. Please email us at ${email}.`, "error");
        } finally {
          submit && (submit.disabled = false);
        }
      });
    });
</script>
