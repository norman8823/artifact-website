---
import Base from "../layouts/Base.astro";
import BackLink from "../components/BackLink.astro";
// Rendered verbatim from the provided policy — see src/content/privacy-policy.md.
import { Content } from "../content/privacy-policy.md";
---

<Base
  title="Privacy Policy — ARtifact"
  description="How ARtifact collects, uses, and protects your information."
>
  <article class="mx-auto max-w-3xl px-6 py-20 sm:py-28">
    <BackLink class="mb-10" />
    <div class="prose">
      <Content />
    </div>
  </article>
</Base>

<style>
  /* Editorial typography matching the site — applied to rendered markdown. */
  .prose :global(h1) {
    font-family: var(--font-serif);
    font-size: clamp(2rem, 5vw, 2.75rem);
    line-height: 1.1;
    letter-spacing: -0.01em;
    margin-bottom: 0.5rem;
  }
  .prose :global(h2) {
    font-family: var(--font-serif);
    font-size: 1.4rem;
    margin-top: 2.75rem;
    margin-bottom: 0.75rem;
    color: var(--color-ink);
  }
  .prose :global(p),
  .prose :global(li) {
    color: var(--color-muted);
    line-height: 1.75;
  }
  .prose :global(p) {
    margin-block: 1rem;
  }
  .prose :global(em) {
    color: var(--color-muted);
    font-style: italic;
  }
  .prose :global(strong) {
    color: var(--color-ink);
    font-weight: 600;
  }
  .prose :global(ul) {
    margin-block: 1rem;
    padding-left: 1.25rem;
    list-style: disc;
  }
  .prose :global(li) {
    margin-block: 0.5rem;
  }
  .prose :global(a) {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .prose :global(a:hover) {
    color: var(--color-accent-hover);
  }
  .prose :global(hr) {
    border: 0;
    border-top: 1px solid var(--color-hairline);
    margin-block: 2.5rem;
  }
</style>
