---
/**
 * The hero centerpiece: a large iPhone frame showing the app demo.
 *
 * We render our (4K) poster image with a prominent play button. On click we
 * mount the Cloudflare Stream iframe and play WITH SOUND and player controls,
 * once (no loop) — the click is the user gesture that lets it play unmuted.
 *
 * When the video ends we use the Cloudflare Stream player SDK to catch the
 * `ended` event, remove the iframe (revealing the crisp poster underneath =
 * the first frame), and restore the play button so it can be replayed.
 *
 * The video file itself is never bundled; it streams from Cloudflare.
 */
import DeviceFrame from "./DeviceFrame.astro";

interface Props {
  maxWidth?: number;
}
const { maxWidth = 400 } = Astro.props;

// Sound on (no `muted`), player controls visible, plays once (no `loop`).
const STREAM_SRC =
  "https://customer-625w28vdwzqne2e8.cloudflarestream.com/95fa3210b11e726d3fc51f6aa4deb989/iframe?autoplay=true&controls=true";
// Freeze frame = the video's OWN first frame, straight from Cloudflare Stream
// (high quality, and identical to what the player shows on play — so there's
// no low-res poster / high-res video mismatch). Not the compressed asset.
const POSTER =
  "https://customer-625w28vdwzqne2e8.cloudflarestream.com/95fa3210b11e726d3fc51f6aa4deb989/thumbnails/thumbnail.jpg?time=0s&height=1600";
---

<DeviceFrame maxWidth={maxWidth} label="ARtifact app demo running on iPhone">
  <div
    class="hero-media"
    data-hero-media
    data-stream-src={STREAM_SRC}
    data-title="ARtifact app demo"
  >
    <img
      class="hero-poster"
      src={POSTER}
      alt="Opening frame of the ARtifact app demo"
      width="390"
      height="830"
      fetchpriority="high"
    />
    <button type="button" class="hero-play" aria-label="Play the ARtifact demo">
      <svg viewBox="0 0 24 24" aria-hidden="true" width="34" height="34">
        <path d="M8 5.5v13l11-6.5-11-6.5Z" fill="currentColor"></path>
      </svg>
    </button>
  </div>
</DeviceFrame>

<style>
  .hero-media {
    position: relative;
    width: 100%;
    height: 100%;
  }
  .hero-media :global(.hero-poster),
  .hero-media :global(iframe) {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .hero-media :global(iframe) {
    z-index: 2;
  }

  .hero-media :global(.hero-play) {
    position: absolute;
    inset: 0;
    z-index: 3;
    display: grid;
    place-items: center;
    width: 100%;
    height: 100%;
    background: transparent;
    border: 0;
    cursor: pointer;
  }
  .hero-media :global(.hero-play)::before {
    content: "";
    position: absolute;
    width: 84px;
    height: 84px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.92);
    box-shadow: 0 6px 24px rgba(0, 0, 0, 0.28);
    transition: transform 0.25s cubic-bezier(0.22, 1, 0.36, 1),
      background-color 0.25s ease;
  }
  .hero-media :global(.hero-play) svg {
    position: relative;
    color: var(--color-accent);
    margin-left: 4px; /* optically centre the triangle */
    transition: transform 0.25s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .hero-media :global(.hero-play):hover::before {
    transform: scale(1.06);
    background: #fff;
  }
  .hero-media :global(.hero-play):hover svg {
    transform: scale(1.06);
  }
  @media (prefers-reduced-motion: reduce) {
    .hero-media :global(.hero-play)::before,
    .hero-media :global(.hero-play) svg {
      transition: none;
    }
  }
</style>

<script>
  const SDK_URL = "https://embed.cloudflarestream.com/embed/sdk.latest.js";
  let sdkPromise: Promise<any> | null = null;

  function loadStreamSdk(): Promise<any> {
    if ((window as any).Stream) return Promise.resolve((window as any).Stream);
    if (!sdkPromise) {
      sdkPromise = new Promise((resolve, reject) => {
        const s = document.createElement("script");
        s.src = SDK_URL;
        s.onload = () => resolve((window as any).Stream);
        s.onerror = reject;
        document.head.appendChild(s);
      });
    }
    return sdkPromise;
  }

  const PLAY_SVG =
    '<svg viewBox="0 0 24 24" aria-hidden="true" width="34" height="34"><path d="M8 5.5v13l11-6.5-11-6.5Z" fill="currentColor"></path></svg>';

  document
    .querySelectorAll<HTMLElement>("[data-hero-media]")
    .forEach((container) => {
      const src = container.dataset.streamSrc;
      const title = container.dataset.title ?? "App demo";
      if (!src) return;

      const makePlayButton = () => {
        const b = document.createElement("button");
        b.type = "button";
        b.className = "hero-play";
        b.setAttribute("aria-label", "Play the ARtifact demo");
        b.innerHTML = PLAY_SVG;
        b.addEventListener("click", start);
        return b;
      };

      function start() {
        const btn = container.querySelector<HTMLButtonElement>(".hero-play");
        if (btn) btn.remove();

        const iframe = document.createElement("iframe");
        iframe.src = src!;
        iframe.title = title;
        iframe.allow =
          "accelerometer; autoplay; encrypted-media; gyroscope; picture-in-picture";
        iframe.setAttribute("allowfullscreen", "");
        container.appendChild(iframe);

        // Reset to the first frame (poster) once the video finishes.
        loadStreamSdk()
          .then((Stream) => {
            if (!Stream) return;
            const player = Stream(iframe);
            player.addEventListener("ended", () => {
              iframe.remove();
              container.appendChild(makePlayButton());
            });
          })
          .catch(() => {
            /* SDK blocked; the player's own controls still allow replay */
          });
      }

      container
        .querySelector<HTMLButtonElement>(".hero-play")
        ?.addEventListener("click", start);
    });
</script>
