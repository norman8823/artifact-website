---
/**
 * A looping UI-recording video inside the iPhone frame.
 *
 * Behaviour:
 *  - muted / loop / playsinline, native autoplay (renders like a device
 *    running the app and paints immediately in every browser)
 *  - pauses when scrolled off-screen, resumes when back on (saves battery)
 *  - respects prefers-reduced-motion: JS pauses playback and shows the first
 *    frame instead of motion
 *  - on mobile, where autoplay is unreliable, shows a small "Tap to play" hint
 *    below the frame whenever the clip isn't playing (tapping the frame or the
 *    hint starts it)
 */
import DeviceFrame from "./DeviceFrame.astro";

interface Props {
  src: string;
  label: string;
  maxWidth?: number;
  class?: string;
}

const { src, label, maxWidth = 300, class: className = "" } = Astro.props;

// Media fragment forces browsers to seek to (and paint) the opening frame,
// so a still is visible before playback — and as the reduced-motion fallback.
const posterSrc = `${src}#t=0.001`;
---

<div
  class:list={["story-media", className]}
  style={`max-width:${maxWidth}px`}
  data-story-wrap
>
  <DeviceFrame maxWidth={maxWidth} label={label}>
    <video
      class="story-video"
      muted
      loop
      autoplay
      playsinline
      preload="metadata"
      aria-label={label}
      data-story-video
    >
      <source src={posterSrc} type="video/mp4" />
    </video>
  </DeviceFrame>
  <button type="button" class="tap-hint" data-tap-hint>Tap to play</button>
</div>

<style>
  .story-media {
    width: 100%;
    margin-inline: auto;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  /* Matches the hero's "Explore" scroll cue: small, spaced, uppercase, muted. */
  .tap-hint {
    display: none;
    margin-top: 0.85rem;
    background: none;
    border: 0;
    cursor: pointer;
    font-size: 0.7rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-muted);
    transition: color 0.25s ease;
  }
  .tap-hint:hover {
    color: var(--color-ink);
  }

  /* Only on mobile, and only while the clip isn't playing. */
  @media (max-width: 639px) {
    .story-media.is-paused .tap-hint {
      display: block;
    }
  }
</style>

<script>
  const prefersReducedMotion = window.matchMedia(
    "(prefers-reduced-motion: reduce)",
  );

  const videos = Array.from(
    document.querySelectorAll<HTMLVideoElement>("video[data-story-video]"),
  );

  const play = (v: HTMLVideoElement) => {
    // iOS Safari blocks autoplay unless `muted` is set as a PROPERTY (the
    // attribute alone is often ignored), so we set it again before every play.
    v.muted = true;
    const p = v.play();
    if (p && typeof p.catch === "function") {
      p.catch(() => {
        /* still blocked (e.g. Low Power Mode); the first frame remains */
      });
    }
  };

  if (videos.length) {
    videos.forEach((v) => {
      v.muted = true; // required for muted autoplay on iOS

      // Track play state so the "Tap to play" hint shows only when paused.
      const wrap = v.closest<HTMLElement>("[data-story-wrap]");
      if (wrap) {
        wrap.classList.add("is-paused");
        v.addEventListener("playing", () => wrap.classList.remove("is-paused"));
        v.addEventListener("play", () => wrap.classList.remove("is-paused"));
        v.addEventListener("pause", () => wrap.classList.add("is-paused"));
        v.addEventListener("ended", () => wrap.classList.add("is-paused"));
        wrap
          .querySelector<HTMLElement>("[data-tap-hint]")
          ?.addEventListener("click", () => play(v));
      }

      // Tapping the clip itself also starts it.
      v.addEventListener("click", () => {
        if (v.paused) play(v);
      });
    });

    if (prefersReducedMotion.matches) {
      // Honour reduced-motion: hold the first frame, don't autoplay.
      videos.forEach((v) => {
        v.autoplay = false;
        v.pause();
        try {
          v.currentTime = 0;
        } catch {
          /* metadata may not be ready yet; the poster frame still shows */
        }
      });
    } else if ("IntersectionObserver" in window) {
      const observer = new IntersectionObserver(
        (entries) => {
          for (const entry of entries) {
            const video = entry.target as HTMLVideoElement;
            if (entry.isIntersecting) play(video);
            else video.pause();
          }
        },
        { threshold: 0.2 },
      );
      videos.forEach((v) => observer.observe(v));

      // Some mobile browsers (e.g. Low Power Mode) block muted autoplay until
      // the first user interaction. Retry any on-screen clips once that happens.
      const kick = () => {
        for (const v of videos) {
          const r = v.getBoundingClientRect();
          if (v.paused && r.top < window.innerHeight && r.bottom > 0) play(v);
        }
      };
      ["touchstart", "pointerdown", "scroll"].forEach((ev) =>
        window.addEventListener(ev, kick, { once: true, passive: true }),
      );
    } else {
      videos.forEach(play);
    }
  }
</script>
