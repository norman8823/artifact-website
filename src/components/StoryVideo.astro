---
/**
 * A looping UI-recording video inside the iPhone frame.
 *
 * Behaviour:
 *  - muted / loop / playsinline, native autoplay (renders like a device
 *    running the app and paints immediately in every browser)
 *  - pauses when scrolled off-screen, resumes when back on (saves battery)
 *  - respects prefers-reduced-motion: JS pauses playback and shows the first
 *    frame instead of motion
 */
import DeviceFrame from "./DeviceFrame.astro";

interface Props {
  src: string;
  label: string;
  maxWidth?: number;
  class?: string;
}

const { src, label, maxWidth = 300, class: className = "" } = Astro.props;

// Media fragment forces browsers to seek to (and paint) the opening frame,
// so a still is visible before playback — and as the reduced-motion fallback.
const posterSrc = `${src}#t=0.001`;
---

<DeviceFrame maxWidth={maxWidth} label={label} class={className}>
  <video
    class="story-video"
    muted
    loop
    autoplay
    playsinline
    preload="metadata"
    aria-label={label}
    data-story-video
  >
    <source src={posterSrc} type="video/mp4" />
  </video>
</DeviceFrame>

<script>
  const prefersReducedMotion = window.matchMedia(
    "(prefers-reduced-motion: reduce)",
  );

  const videos = Array.from(
    document.querySelectorAll<HTMLVideoElement>("video[data-story-video]"),
  );

  const play = (v: HTMLVideoElement) => {
    // iOS Safari blocks autoplay unless `muted` is set as a PROPERTY (the
    // attribute alone is often ignored), so we set it again before every play.
    v.muted = true;
    const p = v.play();
    if (p && typeof p.catch === "function") {
      p.catch(() => {
        /* still blocked (e.g. Low Power Mode); the first frame remains */
      });
    }
  };

  if (videos.length) {
    // Set the muted property up front — required for muted autoplay on iOS.
    videos.forEach((v) => (v.muted = true));

    // Let visitors tap any clip to start it if it isn't already playing.
    videos.forEach((v) =>
      v.addEventListener("click", () => {
        if (v.paused) play(v);
      }),
    );

    if (prefersReducedMotion.matches) {
      // Honour reduced-motion: hold the first frame, don't autoplay.
      videos.forEach((v) => {
        v.autoplay = false;
        v.pause();
        try {
          v.currentTime = 0;
        } catch {
          /* metadata may not be ready yet; the poster frame still shows */
        }
      });
    } else if ("IntersectionObserver" in window) {
      const observer = new IntersectionObserver(
        (entries) => {
          for (const entry of entries) {
            const video = entry.target as HTMLVideoElement;
            if (entry.isIntersecting) play(video);
            else video.pause();
          }
        },
        { threshold: 0.2 },
      );
      videos.forEach((v) => observer.observe(v));

      // Some mobile browsers (e.g. Low Power Mode) block muted autoplay until
      // the first user interaction. Retry any on-screen clips once that happens.
      const kick = () => {
        for (const v of videos) {
          const r = v.getBoundingClientRect();
          if (v.paused && r.top < window.innerHeight && r.bottom > 0) play(v);
        }
      };
      ["touchstart", "pointerdown", "scroll"].forEach((ev) =>
        window.addEventListener(ev, kick, { once: true, passive: true }),
      );
    } else {
      videos.forEach(play);
    }
  }
</script>
